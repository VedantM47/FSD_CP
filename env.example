# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGO_URI=mongodb://localhost:27017/hackathon_db

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=8080
NODE_ENV=development

# ============================================
# JWT AUTHENTICATION (REQUIRED)
# ============================================
# Generate a strong secret (min 32 chars) for production
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_change_this_in_production
JWT_EXPIRES_IN=7d

# ============================================
# CORS & FRONTEND CONFIGURATION
# ============================================
ALLOWED_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080

# ============================================
# OPTIONAL: OAUTH CREDENTIALS
# ============================================
# Leave as placeholder_client_id if not implemented
# Google OAuth: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=placeholder_client_id
GOOGLE_CLIENT_SECRET=placeholder_client_secret

# GitHub OAuth: https://github.com/settings/developers
GITHUB_CLIENT_ID=placeholder_client_id
GITHUB_CLIENT_SECRET=placeholder_client_secret

# ============================================
# OPTIONAL: CLOUDINARY (Resume/File Uploads)
# ============================================
# If not set, resume uploads will use memory storage
# Cloudinary: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# OPTIONAL: EMAIL SERVICE
# ============================================
# Gmail: Use App Password (not main password)
# Enable "Less secure app access" in Gmail settings
EMAIL_USER=
EMAIL_PASS=

# ============================================
# OPTIONAL: OPENAI (Future Feature)
# ============================================
# OPENAI_API_KEY=


